{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"formatWithErrors": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "warn",
				"noArrayIndexKey": "warn"
			},
			"correctness": {
				"useExhaustiveDependencies": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": [
				"apps/fe/components/ui/**",
				"apps/fe/components/niko-table/**",
				"**/_components/*-skeleton.tsx"
			],
			"linter": {
				"rules": {
					"a11y": {
						"useKeyWithClickEvents": "off",
						"useSemanticElements": "off",
						"useFocusableInteractive": "off"
					}
				}
			}
		},
		{
			"includes": ["apps/fe/app/globals.css", "apps/contracts/**"],
			"linter": {
				"enabled": false
			}
		}
	]
}